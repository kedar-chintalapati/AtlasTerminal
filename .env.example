# ─── Atlas Terminal — environment variables ───────────────────────────────────
# Copy this file to .env and fill in your keys.
# All keys are free. None are required to run the app — unfilled keys simply
# disable the corresponding data source.

# ── EIA (Energy Information Administration) ───────────────────────────────────
# Register at: https://www.eia.gov/opendata/register.php  (instant, free)
EIA_API_KEY=

# ── NOAA Climate Data Online ──────────────────────────────────────────────────
# Get token at: https://www.ncdc.noaa.gov/cdo-web/token  (free, email)
NOAA_CDO_TOKEN=

# ── NASA FIRMS (fire detections) ──────────────────────────────────────────────
# Register at: https://firms.modaps.eosdis.nasa.gov/api/  (free, MAP_KEY)
# DEMO_KEY works for testing but has very low rate limits
NASA_FIRMS_MAP_KEY=DEMO_KEY

# ── OpenSky Network (aircraft positions) ──────────────────────────────────────
# Optional — anonymous access is allowed but rate-limited
# Register at: https://opensky-network.org/  (free)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Google Gemini (optional LLM alert explanations) ───────────────────────────
# Leave blank to disable the LLM layer entirely.
# Get a key at: https://aistudio.google.com/apikey  (free tier available)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Storage ──────────────────────────────────────────────────────────────────
DATA_DIR=data
CACHE_DIR=data/cache
PARQUET_DIR=data/parquet
DB_PATH=data/atlas.duckdb

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
